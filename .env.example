# ============================================
# MODEL CONFIGURATION
# ============================================
# Supports any LangChain-compatible model provider.
# Format: "provider:model-name" or just "model-name" (auto-inferred)

# OpenAI Examples:
#   MODEL_NAME=gpt-4-turbo-preview
#   MODEL_NAME=gpt-4
#   MODEL_NAME=gpt-3.5-turbo
#   MODEL_NAME=openai:gpt-4o

# Anthropic Examples:
#   MODEL_NAME=claude-3-5-sonnet-20241022
#   MODEL_NAME=claude-3-opus-20240229
#   MODEL_NAME=anthropic:claude-3-5-sonnet-20241022

# Google Gemini Examples:
#   MODEL_NAME=gemini-1.5-pro
#   MODEL_NAME=gemini-1.5-flash
#   MODEL_NAME=google_genai:gemini-1.5-pro

# Google Vertex AI Examples:
#   MODEL_NAME=vertex_ai:gemini-1.5-pro
#   MODEL_NAME=vertex_ai:gemini-1.5-flash
#   MODEL_NAME=vertex_ai:claude-3-5-sonnet@20240620

# AWS Bedrock Examples:
#   MODEL_NAME=bedrock:anthropic.claude-v2
#   MODEL_NAME=bedrock:amazon.titan-text-express-v1

# Mistral AI Examples:
#   MODEL_NAME=mistral-large-latest
#   MODEL_NAME=mistral-medium-latest

# Groq Examples:
#   MODEL_NAME=mixtral-8x7b-32768
#   MODEL_NAME=llama-3.1-70b-versatile

# Cohere Examples:
#   MODEL_NAME=command-r-plus
#   MODEL_NAME=command-r

MODEL_NAME=gpt-4-turbo-preview
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=1000

# ============================================
# API KEYS (set the ones you need)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# Google Vertex AI Configuration (for vertex_ai: models)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# AWS_ACCESS_KEY_ID=your_aws_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_here
# MISTRAL_API_KEY=your_mistral_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# COHERE_API_KEY=your_cohere_api_key_here

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Rate limiting (requests per minute, per client IP and per endpoint)
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_CHECK_DIFF_PER_MINUTE=20
API_RATE_LIMIT_HEALTH_PER_MINUTE=600
API_RATE_LIMIT_TOOLS_PER_MINUTE=120
API_RATE_LIMIT_ROOT_PER_MINUTE=120

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=AI Agent
APP_VERSION=1.0.0
LOG_LEVEL=INFO
